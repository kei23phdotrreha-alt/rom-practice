<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ROM測定 練習アプリ</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=DM+Mono:wght@400;500&display=swap');

  :root {
    --navy: #0F2044;
    --navy2: #1A3460;
    --gold: #C9A84C;
    --gold2: #E8C96A;
    --cream: #F7F3EC;
    --cream2: #EDE7DC;
    --green: #2D6A4F;
    --green-light: #D8F3DC;
    --red: #9B2226;
    --red-light: #FFDDD2;
    --text: #1a1a2e;
    --text2: #4a4a6a;
    --radius: 16px;
    --radius-sm: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background: var(--cream);
    color: var(--text);
    min-height: 100dvh;
    overflow-x: hidden;
  }

  /* ===== SCREENS ===== */
  .screen { display: none; min-height: 100dvh; flex-direction: column; }
  .screen.active { display: flex; }

  /* ===== HOME ===== */
  #home {
    background: var(--navy);
    position: relative;
    overflow: hidden;
  }
  #home::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.18) 0%, transparent 70%);
  }
  #home::after {
    content: '';
    position: absolute;
    bottom: 60px; left: -60px;
    width: 240px; height: 240px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.10) 0%, transparent 70%);
  }

  .home-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 48px 24px 32px;
    position: relative;
    z-index: 1;
  }

  .app-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(201,168,76,0.15);
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 100px;
    padding: 6px 14px;
    font-size: 11px;
    font-weight: 500;
    color: var(--gold2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 28px;
    width: fit-content;
  }

  .home-title {
    font-size: 32px;
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .home-title span { color: var(--gold); }

  .home-sub {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  /* Stats dashboard */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 32px;
  }
  .stat-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius);
    padding: 16px;
  }
  .stat-card.gold-border { border-color: rgba(201,168,76,0.4); }
  .stat-label {
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .stat-value {
    font-family: 'DM Mono', monospace;
    font-size: 28px;
    font-weight: 500;
    color: #fff;
    line-height: 1;
  }
  .stat-value.gold { color: var(--gold); }
  .stat-unit { font-size: 13px; color: rgba(255,255,255,0.4); margin-left: 2px; }

  /* Weak section preview */
  .weak-preview {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius);
    padding: 16px;
    margin-bottom: 32px;
  }
  .weak-preview-title {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .weak-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .weak-tag {
    background: rgba(155,34,38,0.3);
    border: 1px solid rgba(155,34,38,0.5);
    border-radius: 100px;
    padding: 4px 10px;
    font-size: 12px;
    color: #ffb3b3;
  }
  .no-weak {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
  }

  /* Mode buttons */
  .mode-section { margin-bottom: 16px; }
  .mode-title {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .mode-btn {
    width: 100%;
    padding: 18px 20px;
    border-radius: var(--radius);
    border: none;
    cursor: pointer;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 15px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: transform 0.15s, opacity 0.15s;
    margin-bottom: 10px;
  }
  .mode-btn:active { transform: scale(0.97); opacity: 0.85; }
  .mode-btn.primary {
    background: linear-gradient(135deg, var(--gold) 0%, #a07830 100%);
    color: var(--navy);
  }
  .mode-btn.secondary {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
  }
  .mode-btn.danger {
    background: rgba(155,34,38,0.2);
    border: 1px solid rgba(155,34,38,0.4);
    color: #ffb3b3;
  }
  .mode-btn .btn-left { display: flex; align-items: center; gap: 10px; }
  .mode-btn .btn-icon { font-size: 20px; }
  .mode-btn .btn-desc { font-size: 11px; font-weight: 400; opacity: 0.7; display: block; margin-top: 2px; text-align: left; }
  .mode-btn .btn-arrow { font-size: 18px; opacity: 0.6; }
  .reset-btn {
    width: 100%;
    background: none;
    border: none;
    color: rgba(255,255,255,0.25);
    font-size: 12px;
    font-family: 'Noto Sans JP', sans-serif;
    padding: 8px;
    cursor: pointer;
    text-align: center;
    margin-top: 4px;
  }

  /* ===== QUIZ SCREEN ===== */
  #quiz {
    background: var(--cream);
    flex-direction: column;
  }

  .quiz-header {
    background: var(--navy);
    padding: 16px 20px 20px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .quiz-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .back-btn {
    background: rgba(255,255,255,0.1);
    border: none;
    border-radius: 100px;
    padding: 8px 14px;
    color: rgba(255,255,255,0.7);
    font-size: 13px;
    font-family: 'Noto Sans JP', sans-serif;
    cursor: pointer;
  }
  .quiz-mode-label {
    font-size: 12px;
    color: var(--gold);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .quiz-counter {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: rgba(255,255,255,0.5);
  }

  .progress-track {
    height: 3px;
    background: rgba(255,255,255,0.1);
    border-radius: 100px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold) 0%, var(--gold2) 100%);
    border-radius: 100px;
    transition: width 0.4s ease;
  }

  .quiz-body {
    flex: 1;
    padding: 24px 20px 100px;
    overflow-y: auto;
  }

  .section-chip {
    display: inline-flex;
    align-items: center;
    background: var(--navy);
    color: var(--gold);
    border-radius: 100px;
    padding: 5px 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 16px;
  }

  .question-card {
    background: #fff;
    border-radius: var(--radius);
    padding: 22px 20px;
    margin-bottom: 20px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }
  .question-num {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text2);
    opacity: 0.6;
    margin-bottom: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .question-text {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.65;
    color: var(--navy);
  }

  .choices {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
  }
  .choice-btn {
    width: 100%;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.1);
    border-radius: var(--radius-sm);
    padding: 15px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 14px;
    color: var(--text);
    text-align: left;
    line-height: 1.5;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }
  .choice-btn:active { transform: scale(0.98); }
  .choice-label {
    min-width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--cream2);
    color: var(--navy);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-family: 'DM Mono', monospace;
  }
  .choice-btn.correct {
    background: var(--green-light);
    border-color: var(--green);
  }
  .choice-btn.correct .choice-label {
    background: var(--green);
    color: #fff;
  }
  .choice-btn.wrong {
    background: var(--red-light);
    border-color: var(--red);
  }
  .choice-btn.wrong .choice-label {
    background: var(--red);
    color: #fff;
  }
  .choice-btn.disabled { pointer-events: none; opacity: 0.5; }

  /* Explanation */
  .explanation {
    background: var(--navy);
    border-radius: var(--radius);
    padding: 18px 18px;
    margin-bottom: 16px;
    display: none;
  }
  .explanation.show { display: block; }
  .exp-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }
  .exp-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }
  .exp-badge.ok { background: rgba(45,106,79,0.4); color: #95d5b2; }
  .exp-badge.ng { background: rgba(155,34,38,0.4); color: #ffb3b3; }
  .exp-text {
    font-size: 13px;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
  }

  /* Next button */
  .next-area {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, var(--cream) 70%, transparent);
    padding: 16px 20px 28px;
    display: none;
  }
  .next-area.show { display: block; }
  .next-btn {
    width: 100%;
    padding: 17px;
    background: var(--navy);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .next-btn:active { transform: scale(0.97); opacity: 0.85; }
  .next-btn.gold-btn {
    background: linear-gradient(135deg, var(--gold) 0%, #a07830 100%);
    color: var(--navy);
  }

  /* ===== RESULT SCREEN ===== */
  #result {
    background: var(--navy);
    overflow-y: auto;
  }
  .result-inner {
    padding: 48px 24px 48px;
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }
  .result-title {
    font-size: 13px;
    color: var(--gold);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .score-ring-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }
  .score-ring {
    position: relative;
    width: 160px;
    height: 160px;
  }
  .score-ring svg {
    width: 160px;
    height: 160px;
    transform: rotate(-90deg);
  }
  .score-ring-bg { fill: none; stroke: rgba(255,255,255,0.08); stroke-width: 10; }
  .score-ring-fill { fill: none; stroke-width: 10; stroke-linecap: round; transition: stroke-dashoffset 1s ease; }
  .score-center {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    text-align: center;
  }
  .score-pct {
    font-family: 'DM Mono', monospace;
    font-size: 36px;
    font-weight: 500;
    color: #fff;
    line-height: 1;
  }
  .score-pct-sym { font-size: 18px; color: rgba(255,255,255,0.5); }
  .score-grade {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin-top: 4px;
  }

  .result-stats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 28px;
  }
  .r-stat {
    background: rgba(255,255,255,0.06);
    border-radius: var(--radius-sm);
    padding: 14px 10px;
    text-align: center;
  }
  .r-stat-n {
    font-family: 'DM Mono', monospace;
    font-size: 24px;
    font-weight: 500;
    line-height: 1;
    margin-bottom: 4px;
  }
  .r-stat-l { font-size: 11px; color: rgba(255,255,255,0.4); }
  .r-stat-n.green { color: #95d5b2; }
  .r-stat-n.red { color: #ffb3b3; }
  .r-stat-n.gold { color: var(--gold); }

  /* Wrong list */
  .wrong-section { margin-bottom: 28px; }
  .wrong-title {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .wrong-item {
    background: rgba(155,34,38,0.15);
    border: 1px solid rgba(155,34,38,0.3);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    margin-bottom: 8px;
  }
  .wrong-q { font-size: 13px; color: rgba(255,255,255,0.8); line-height: 1.5; margin-bottom: 8px; }
  .wrong-ans { font-size: 12px; color: #ffb3b3; margin-bottom: 3px; }
  .wrong-cor { font-size: 12px; color: #95d5b2; }

  .result-btns { display: flex; flex-direction: column; gap: 10px; }
  .result-btn {
    width: 100%;
    padding: 17px;
    border-radius: var(--radius);
    border: none;
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s, opacity 0.15s;
  }
  .result-btn:active { transform: scale(0.97); opacity: 0.85; }
  .result-btn.primary {
    background: linear-gradient(135deg, var(--gold) 0%, #a07830 100%);
    color: var(--navy);
  }
  .result-btn.outline {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
  }
  .result-btn.danger-outline {
    background: rgba(155,34,38,0.15);
    border: 1px solid rgba(155,34,38,0.35);
    color: #ffb3b3;
  }

  /* Section bar chart */
  .section-chart { margin-bottom: 28px; }
  .sc-title {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .sc-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .sc-label { font-size: 12px; color: rgba(255,255,255,0.6); width: 90px; flex-shrink: 0; line-height: 1.3; }
  .sc-bar-wrap { flex: 1; height: 8px; background: rgba(255,255,255,0.08); border-radius: 100px; overflow: hidden; }
  .sc-bar { height: 100%; border-radius: 100px; transition: width 0.8s ease; }
  .sc-pct { font-family: 'DM Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.4); width: 34px; text-align: right; flex-shrink: 0; }

  /* Toast */
  .toast {
    position: fixed;
    top: 20px; left: 50%;
    transform: translateX(-50%) translateY(-80px);
    background: var(--navy);
    color: #fff;
    padding: 10px 20px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 500;
    z-index: 999;
    transition: transform 0.3s ease;
    white-space: nowrap;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .toast.show { transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>

<!-- HOME -->
<div class="screen active" id="home">
  <div class="home-inner">
    <div class="app-badge">🩺 ROM測定 練習アプリ</div>
    <div class="home-title">関節可動域測定<br><span>マスターしよう</span></div>
    <div class="home-sub">50問・ランダム出題<br>正答率・苦手問題を自動記録</div>

    <div class="stats-grid">
      <div class="stat-card gold-border">
        <div class="stat-label">累計正答率</div>
        <div class="stat-value gold" id="home-rate">—<span class="stat-unit">%</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">挑戦回数</div>
        <div class="stat-value" id="home-attempts">0<span class="stat-unit">回</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">正解数(累計)</div>
        <div class="stat-value" id="home-correct">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">苦手問題</div>
        <div class="stat-value" id="home-weak">0<span class="stat-unit">問</span></div>
      </div>
    </div>

    <div class="weak-preview">
      <div class="weak-preview-title">⚠️ 苦手セクション（正答率50%未満）</div>
      <div class="weak-tags" id="weak-section-tags">
        <span class="no-weak">まだデータがありません</span>
      </div>
    </div>

    <div class="mode-section">
      <div class="mode-title">練習モードを選ぶ</div>
      <button class="mode-btn primary" onclick="startQuiz('all')">
        <div class="btn-left">
          <span class="btn-icon">🎲</span>
          <div>
            全50問ランダム
            <span class="btn-desc">すべての問題をシャッフル出題</span>
          </div>
        </div>
        <span class="btn-arrow">→</span>
      </button>
      <button class="mode-btn secondary" onclick="startQuiz('weak')">
        <div class="btn-left">
          <span class="btn-icon">🎯</span>
          <div>
            苦手問題のみ
            <span class="btn-desc">正答率50%未満の問題を集中練習</span>
          </div>
        </div>
        <span class="btn-arrow">→</span>
      </button>
    </div>

    <button class="reset-btn" onclick="confirmReset()">履歴をリセット</button>
  </div>
</div>

<!-- QUIZ -->
<div class="screen" id="quiz">
  <div class="quiz-header">
    <div class="quiz-nav">
      <button class="back-btn" onclick="goHome()">← ホーム</button>
      <span class="quiz-mode-label" id="quiz-mode-label">ランダム</span>
      <span class="quiz-counter" id="quiz-counter">1 / 50</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progress-fill" style="width:2%"></div>
    </div>
  </div>

  <div class="quiz-body" id="quiz-body"></div>

  <div class="next-area" id="next-area">
    <button class="next-btn" id="next-btn" onclick="nextQuestion()">次の問題 →</button>
  </div>
</div>

<!-- RESULT -->
<div class="screen" id="result">
  <div class="result-inner">
    <div class="result-title">📊 セッション結果</div>

    <div class="score-ring-wrap">
      <div class="score-ring">
        <svg viewBox="0 0 160 160">
          <circle class="score-ring-bg" cx="80" cy="80" r="70"/>
          <circle class="score-ring-fill" id="ring-fill" cx="80" cy="80" r="70"
            stroke-dasharray="439.8" stroke-dashoffset="439.8"/>
        </svg>
        <div class="score-center">
          <div class="score-pct" id="result-pct">0<span class="score-pct-sym">%</span></div>
          <div class="score-grade" id="result-grade">—</div>
        </div>
      </div>
    </div>

    <div class="result-stats">
      <div class="r-stat">
        <div class="r-stat-n green" id="r-correct">0</div>
        <div class="r-stat-l">正解</div>
      </div>
      <div class="r-stat">
        <div class="r-stat-n red" id="r-wrong">0</div>
        <div class="r-stat-l">不正解</div>
      </div>
      <div class="r-stat">
        <div class="r-stat-n gold" id="r-total">0</div>
        <div class="r-stat-l">出題数</div>
      </div>
    </div>

    <div class="section-chart">
      <div class="sc-title">📌 セクション別正答率</div>
      <div id="section-chart-body"></div>
    </div>

    <div class="wrong-section" id="wrong-section"></div>

    <div class="result-btns">
