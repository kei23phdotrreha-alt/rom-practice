<script>
const QUESTIONS = [
  {id:0,sec:"測定法・概念",q:"ROM測定において、原則として用いる測定方法はどれか。",choices:["自動ROM（被検者自身が動かす）","他動ROM（検者が動かす）","自動と他動の平均値","最大努力での自動ROM"],ans:1,exp:"原則として他動ROMで測定する。痛みや手術後など他動が禁忌の場合のみ自動ROMを測定する。"},
  {id:1,sec:"測定法・概念",q:"関節可動域測定の基本肢位（開始肢位）として正しいのはどれか。",choices:["最大屈曲位","解剖学的肢位（中間位ゼロ開始肢位）","機能的肢位","最大伸展位"],ans:1,exp:"関節運動は解剖学的肢位（neutral zero starting position：中間位ゼロ開始肢位）を基本肢位とする。"},
  {id:2,sec:"測定法・概念",q:"角度計（ゴニオメーター）の固定アームは原則としてどこに当てるか。",choices:["関節の遠位部（移動軸）","関節の近位部（基本軸）","関節の中心点","測定しやすい場所"],ans:1,exp:"固定アームは基本軸（関節の近位部）に、可動アームは移動軸（遠位部）に当てる。"},
  {id:3,sec:"測定法・概念",q:"ROM測定の記録方法として正しいのはどれか。",choices:["最終肢位の角度のみ記録する","開始肢位と最終肢位の2回の値を記録する","最大値と最小値の平均を記録する","自動ROMと他動ROMの差を記録する"],ans:1,exp:"開始肢位と最終肢位の2回の値を記録する。例：肩関節屈曲 0～130°"},
  {id:4,sec:"測定法・概念",q:"痙縮（spasticity）によりROM制限がみられた場合、測定値への付記として正しいのはどれか。",choices:["測定値の後に「P」を付記する","測定値の後に「SJ」を付記する","測定値の後に「SP」を付記する","特に付記しない"],ans:1,exp:"痙縮（spasticity）は「SJ」、痛み（pain）は「P」を測定値の後ろ（または前）に付記する。"},
  {id:5,sec:"測定法・概念",q:"ROM制限が生じる最大の理由はどれか。",choices:["加齢","不動（固定）","疼痛","筋力低下"],ans:1,exp:"ROM制限発生の最大の理由は不動（固定）である。意識障害、麻痺、外傷などが不動をもたらす。"},
  {id:6,sec:"測定法・概念",q:"他動ROM測定時の注意点として正しいのはどれか。",choices:["一般に関節の遠位部を固定し近位部を動かす","他動運動中に痛みが生じても最終域まで動かす","他動的な力は近位部および遠位部に加える","代償運動は多少許容してよい"],ans:2,exp:"他動的な力は近位部および遠位部に加える。一般に近位部を固定し遠位部を動かす。痛みが生じたらその角度で止め、代償運動は防止する。"},
  {id:7,sec:"測定法・概念",q:"ROM測定の正確性に影響する因子として誤っているのはどれか。",choices:["被検者の恐れや緊張","測定時間や温度・天候","角度計の目盛りの読み違い","測定者の年齢"],ans:3,exp:"正確性に影響する因子は①被検者側の因子②測定時間・温度・天候③目盛りの読み違い④測定方法⑤測定技術である。測定者の年齢は挙げられていない。"},
  {id:8,sec:"測定法・概念",q:"測定前の確認事項として正しいのはどれか。",choices:["関節痛の有無など被検者から聴取し炎症症状を確認する","感覚障害の確認は測定後に行う","角度計を使って先に測定してから自動運動を観察する","骨粗鬆症があれば他動ROMは禁忌のため測定しない"],ans:0,exp:"測定前に関節痛の有無を聴取し、発赤・腫脹などの炎症症状や皮膚状態を観察する。角度計使用前に自動運動を観察することも重要。"},
  {id:9,sec:"測定法・概念",q:"ROM測定が禁忌となる状況として正しいのはどれか。",choices:["軽度の筋力低下がある場合","関節脱臼・骨折や軟部組織の手術直後","高齢者で骨密度が低い場合","感覚障害がある場合"],ans:1,exp:"関節脱臼、骨折や軟部組織の手術直後、関節の強い炎症、化骨性筋炎などは禁忌となる。"},
  {id:10,sec:"測定法・概念",q:"ROM測定の意義として正しいのはどれか。",choices:["筋力の絶対値を評価する","随意運動の基礎となり他の運動機能検査の判定基準となる","痛みの程度を数値化する","関節の安定性を評価する"],ans:1,exp:"ROM測定は随意運動の基礎となり、他の運動機能検査測定の判定基準となる。治療目標設定や治療効果判定にも用いる。"},
  {id:11,sec:"測定法・概念",q:"関節運動の運動面の説明として正しいのはどれか。",choices:["矢状面は身体を前後に分ける面である","前額面は身体を左右に分ける面である","水平面は身体を上下に分ける面である","垂直軸は前額面に直交する軸である"],ans:2,exp:"水平面は身体を上下に分ける面。矢状面は身体を左右に分ける面、前額面は身体を前後に分ける面である。"},
  {id:12,sec:"測定法・概念",q:"測定の手順として正しい順序はどれか。",choices:["開始肢位確認→最終肢位まで動かす→角度計装着→記録","被検者を開始肢位にする→骨指標確認・角度計装着→開始角度読み取り→最終肢位まで動かして角度読み取り","角度計装着→被検者を開始肢位にする→最終肢位まで動かす→記録","最終肢位まで動かす→開始肢位に戻す→角度計装着→記録"],ans:1,exp:"正しい手順：①開始肢位にする②骨指標確認・角度計装着③開始角度読取④角度計外し最終肢位まで動かす⑤再度角度計装着し最終角度読取⑥開始肢位に戻す⑦記録。"},
  {id:13,sec:"測定法・概念",q:"動筋と拮抗筋の関係についてROM制限との関連で正しいのはどれか。",choices:["動筋と拮抗筋の筋力が均衡しているとROM制限が起こりやすい","動筋と拮抗筋の筋力の不均衡化によってもROM制限が起こることがある","拮抗筋が強いほどROMは大きくなる","動筋が弱いとROMは増大する"],ans:1,exp:"動筋と拮抗筋の筋力の不均衡化によってもROM制限が起こることがある。"},
  {id:14,sec:"測定法・概念",q:"関節リウマチ患者のROM測定で特に注意すべき因子はどれか。",choices:["測定者の利き手","測定場所の広さ","服薬時間や測定時間・温度・天候","被検者の年齢"],ans:2,exp:"関節リウマチなどの関節疾患では服薬時間や測定時間、温度、天候によって関節の痛みが変化し、ROMに影響することがある。"},
  {id:15,sec:"肩甲帯",q:"肩甲帯屈曲・伸展の基本軸として正しいのはどれか。",choices:["肩峰と胸骨上縁を結ぶ線","両側の肩峰を結ぶ線","肩峰を通る床への垂直線","頭頂と肩峰を結ぶ線"],ans:1,exp:"肩甲帯屈曲・伸展の基本軸は「両側の肩峰を結ぶ線」、移動軸は「頭頂と肩峰を結ぶ線」である。"},
  {id:16,sec:"肩甲帯",q:"肩甲帯屈曲・伸展の参考可動域として正しいのはどれか。",choices:["屈曲0〜10°・伸展0〜10°","屈曲0〜20°・伸展0〜20°","屈曲0〜30°・伸展0〜30°","屈曲0〜20°・伸展0〜10°"],ans:1,exp:"肩甲帯屈曲・伸展の参考可動域はともに0〜20°である。"},
  {id:17,sec:"肩甲帯",q:"肩甲帯挙上・引き下げ（下制）の参考可動域として正しいのはどれか。",choices:["挙上0〜10°・引き下げ0〜10°","挙上0〜20°・引き下げ0〜10°","挙上0〜20°・引き下げ0〜20°","挙上0〜30°・引き下げ0〜10°"],ans:1,exp:"肩甲帯挙上は0〜20°、引き下げ（下制）は0〜10°が参考可動域である。"},
  {id:18,sec:"肩甲帯",q:"肩甲帯挙上・引き下げの測定に関して正しいのはどれか。",choices:["前面から測定する","背面から測定する","側面から測定する","どの面からでもよい"],ans:1,exp:"肩甲帯の挙上・引き下げは背面から測定する。基本軸は両側の肩峰を結ぶ線、移動軸は肩峰と胸骨上縁を結ぶ線。"},
  {id:19,sec:"肩関節",q:"肩関節屈曲（前方挙上）の参考可動域として正しいのはどれか。",choices:["0〜90°","0〜120°","0〜150°","0〜180°"],ans:3,exp:"肩関節屈曲（前方挙上）の参考可動域は0〜180°。基本軸は肩峰を通る床への垂直線、移動軸は上腕骨。"},
  {id:20,sec:"肩関節",q:"肩関節屈曲（前方挙上）測定時の注意点として正しいのはどれか。",choices:["前腕を回内位とする","体幹が動かないように固定し脊柱が前後屈しないよう注意する","肘関節を屈曲位で測定する","肩関節を90°外転位で行う"],ans:1,exp:"肩関節屈曲は前腕を中間位とし、体幹が動かないように固定する。脊柱が前後屈しないように注意する。"},
  {id:21,sec:"肩関節",q:"肩関節外転（側方挙上）の参考可動域と測定時の注意点の組み合わせとして正しいのはどれか。",choices:["0〜90°・前腕を回内する","0〜180°・90°以上で前腕を回外する","0〜180°・前腕は常に回内位を保つ","0〜150°・90°以上で前腕を回内する"],ans:1,exp:"肩関節外転の参考可動域は0〜180°。体幹の側屈が起こらないようにし、90°以上になったら前腕を回外することを原則とする。"},
  {id:22,sec:"肩関節",q:"肩関節外旋・内旋（標準法）の参考可動域として正しいのはどれか。",choices:["外旋0〜45°・内旋0〜60°","外旋0〜60°・内旋0〜80°","外旋0〜80°・内旋0〜60°","外旋0〜60°・内旋0〜60°"],ans:1,exp:"肩関節外旋は0〜60°、内旋は0〜80°が参考可動域。上腕を体幹に接し肘を90°屈曲した肢位で行う。移動軸は尺骨。"},
  {id:23,sec:"肩関節",q:"肩関節水平屈曲（水平内転）の参考可動域として正しいのはどれか。",choices:["0〜90°","0〜100°","0〜135°","0〜150°"],ans:2,exp:"肩関節水平屈曲（horizontal adduction）の参考可動域は0〜135°。肩関節を90°外転位として測定する。"},
  {id:24,sec:"肩関節",q:"肩関節内転の参考可動域として正しいのはどれか。",choices:["0°（解剖学的肢位で0°）","0〜20°","0〜30°","0〜45°"],ans:0,exp:"肩関節内転の参考可動域は0°（解剖学的肢位が最大内転位のため）。測定には他側下肢を屈曲挙上させてその下を通す方法をとる。"},
  {id:25,sec:"肘関節・前腕",q:"肘関節屈曲の参考可動域と移動軸の組み合わせとして正しいのはどれか。",choices:["0〜120°・尺骨","0〜145°・橈骨","0〜145°・尺骨","0〜160°・橈骨"],ans:1,exp:"肘関節屈曲の参考可動域は0〜145°、移動軸は橈骨である。前腕は回外位で測定する。"},
  {id:26,sec:"肘関節・前腕",q:"肘関節伸展の参考可動域として正しいのはどれか。",choices:["0°","0〜5°","0〜10°","0〜15°"],ans:1,exp:"肘関節伸展の参考可動域は0〜5°である。"},
  {id:27,sec:"肘関節・前腕",q:"前腕回内・回外の参考可動域として正しいのはどれか。",choices:["回内0〜80°・回外0〜90°","回内0〜90°・回外0〜90°","回内0〜90°・回外0〜80°","回内0〜80°・回外0〜80°"],ans:1,exp:"前腕回内・回外はともに0〜90°。肩の回旋が入らないように肘を90°に屈曲して測定する。移動軸は手指を伸展した手掌面。"},
  {id:28,sec:"肘関節・前腕",q:"前腕回内・回外測定時の注意点として正しいのはどれか。",choices:["肘関節を伸展位で行う","肩の回旋が入らないように肘を90°に屈曲する","前腕は回外位で固定して行う","肩関節を90°外転した肢位で行う"],ans:1,exp:"肩の回旋が入らないように肘を90°に屈曲して測定する。基本軸は上腕骨、移動軸は手指を伸展した手掌面。"},
  {id:29,sec:"手関節",q:"手関節屈曲（掌屈）・伸展（背屈）の参考可動域として正しいのはどれか。",choices:["掌屈0〜80°・背屈0〜70°","掌屈0〜90°・背屈0〜70°","掌屈0〜90°・背屈0〜80°","掌屈0〜80°・背屈0〜80°"],ans:1,exp:"手関節掌屈は0〜90°、背屈は0〜70°。基本軸は橈骨、移動軸は第2中手骨。前腕は中間位とする。"},
  {id:30,sec:"手関節",q:"手関節橈屈・尺屈の参考可動域として正しいのはどれか。",choices:["橈屈0〜25°・尺屈0〜55°","橈屈0〜30°・尺屈0〜45°","橈屈0〜20°・尺屈0〜50°","橈屈0〜25°・尺屈0〜45°"],ans:0,exp:"手関節橈屈は0〜25°、尺屈は0〜55°。基本軸は前腕の中央線、移動軸は第3中手骨。前腕を回内位で行う。"},
  {id:31,sec:"手関節",q:"手関節屈曲（掌屈）の基本軸と移動軸の組み合わせとして正しいのはどれか。",choices:["橈骨・第3中手骨","橈骨・第2中手骨","尺骨・第2中手骨","前腕中央線・第3中手骨"],ans:1,exp:"手関節屈曲（掌屈）の基本軸は橈骨、移動軸は第2中手骨。前腕は中間位とする。"},
  {id:32,sec:"手関節",q:"手関節橈屈・尺屈測定時の前腕の肢位として正しいのはどれか。",choices:["前腕回外位","前腕中間位","前腕回内位","どの肢位でもよい"],ans:2,exp:"手関節橈屈・尺屈は前腕を回内位で行う。基本軸は前腕の中央線、移動軸は第3中手骨。"},
  {id:33,sec:"手指・母指",q:"母指MCP関節屈曲の参考可動域・基本軸・移動軸の組み合わせとして正しいのはどれか。",choices:["0〜60°・第1中手骨・第1基節骨","0〜80°・第1中手骨・第1基節骨","0〜60°・第1基節骨・第1末節骨","0〜80°・第1基節骨・第1末節骨"],ans:0,exp:"母指MCP関節屈曲は0〜60°、基本軸は第1中手骨、移動軸は第1基節骨。"},
  {id:34,sec:"手指・母指",q:"母指IP関節屈曲の参考可動域・基本軸・移動軸の組み合わせとして正しいのはどれか。",choices:["0〜60°・第1中手骨・第1基節骨","0〜80°・第1基節骨・第1末節骨","0〜80°・第1中手骨・第1末節骨","0〜60°・第1基節骨・第1末節骨"],ans:1,exp:"母指IP関節屈曲は0〜80°、基本軸は第1基節骨、移動軸は第1末節骨。"},
  {id:35,sec:"手指・母指",q:"母指橈側外転・掌側外転の参考可動域として正しいのはどれか。",choices:["橈側外転0〜60°・掌側外転0〜90°","橈側外転0〜90°・掌側外転0〜60°","橈側外転0〜45°・掌側外転0〜60°","橈側外転0〜60°・掌側外転0〜60°"],ans:0,exp:"母指橈側外転は0〜60°、掌側外転は0〜90°が参考可動域。橈側外転の基本軸は示指（橈骨の延長上）、移動軸は母指。"},
  {id:36,sec:"手指・母指",q:"手指（示指〜小指）MCP関節屈曲・伸展の参考可動域として正しいのはどれか。",choices:["屈曲0〜80°・伸展0〜30°","屈曲0〜90°・伸展0〜45°","屈曲0〜100°・伸展0〜45°","屈曲0〜90°・伸展0〜30°"],ans:1,exp:"手指MCP関節屈曲は0〜90°、伸展は0〜45°。基本軸は第2〜5中手骨、移動軸は第2〜5基節骨。"},
  {id:37,sec:"手指・母指",q:"手指（示指〜小指）PIP関節屈曲の参考可動域として正しいのはどれか。",choices:["0〜80°","0〜90°","0〜100°","0〜110°"],ans:2,exp:"手指PIP関節屈曲の参考可動域は0〜100°。基本軸は第2〜5基節骨、移動軸は第2〜5中節骨。"},
  {id:38,sec:"手指・母指",q:"手指（示指〜小指）DIP関節屈曲の参考可動域として正しいのはどれか。",choices:["0〜60°","0〜70°","0〜80°","0〜90°"],ans:2,exp:"手指DIP関節屈曲の参考可動域は0〜80°。基本軸は第2〜5中節骨、移動軸は第2〜5末節骨。DIPは10°の過伸展をとりうる。"},
  {id:39,sec:"手指・母指",q:"手指の外転・内転測定に関して正しいのはどれか。",choices:["外転・内転の基本軸は第2中手骨延長線で移動軸は第2・4・5指軸","外転・内転の基本軸は第3中手骨延長線で移動軸は第2・4・5指軸","外転・内転の基本軸は第3中手骨延長線で移動軸は全指軸","中指の運動は屈曲・伸展とする"],ans:1,exp:"手指外転・内転の基本軸は第3中手骨延長線、移動軸は第2・4・5指軸。中指の運動は橈側外転・尺側外転とする。"},
  {id:40,sec:"股関節",q:"股関節屈曲の参考可動域と測定肢位の組み合わせとして正しいのはどれか。",choices:["0〜110°・背臥位膝屈曲位","0〜125°・背臥位膝屈曲位","0〜125°・腹臥位膝伸展位","0〜135°・背臥位膝伸展位"],ans:1,exp:"股関節屈曲は0〜125°、背臥位・膝屈曲位で測定。伸展は0〜15°、腹臥位・膝伸展位で行う。基本軸は体幹と平行な線、移動軸は大腿骨。"},
  {id:41,sec:"股関節",q:"股関節外転の参考可動域と移動軸として正しいのはどれか。",choices:["0〜30°・大腿中央線","0〜45°・大腿中央線","0〜30°・下腿中央線","0〜45°・下腿中央線"],ans:1,exp:"股関節外転の参考可動域は0〜45°、移動軸は大腿中央線（上前腸骨棘より膝蓋骨中心を結ぶ線）。基本軸は両側上前腸骨棘を結ぶ線への垂直線。"},
  {id:42,sec:"股関節",q:"股関節内転の参考可動域として正しいのはどれか。",choices:["0〜10°","0〜20°","0〜30°","0〜45°"],ans:1,exp:"股関節内転の参考可動域は0〜20°。内転の場合は反対側の下肢を屈曲挙上してその下を通して内転させる。"},
  {id:43,sec:"股関節",q:"股関節外旋・内旋の参考可動域として正しいのはどれか。",choices:["外旋0〜30°・内旋0〜30°","外旋0〜45°・内旋0〜45°","外旋0〜45°・内旋0〜30°","外旋0〜60°・内旋0〜45°"],ans:1,exp:"股関節外旋・内旋ともに0〜45°が参考可動域。背臥位で股関節と膝関節を90°屈曲位にして行う。"},
  {id:44,sec:"股関節",q:"股関節外旋・内旋の測定肢位として正しいのはどれか。",choices:["腹臥位で膝関節を伸展した肢位","背臥位で股関節と膝関節を90°屈曲した肢位","立位で股関節を中間位にした肢位","側臥位で股関節を30°屈曲した肢位"],ans:1,exp:"股関節外旋・内旋は背臥位で股関節と膝関節を90°屈曲位にして行う。骨盤の代償を少なくする。"},
  {id:45,sec:"膝関節",q:"膝関節屈曲の参考可動域と移動軸として正しいのはどれか。",choices:["0〜120°・腓骨（腓骨頭と外果を結ぶ線）","0〜130°・腓骨（腓骨頭と外果を結ぶ線）","0〜130°・下腿中央線","0〜145°・腓骨（腓骨頭と外果を結ぶ線）"],ans:1,exp:"膝関節屈曲の参考可動域は0〜130°、基本軸は大腿骨、移動軸は腓骨（腓骨頭と外果を結ぶ線）。屈曲は股関節を屈曲位で行う。"},
  {id:46,sec:"膝関節",q:"膝関節屈曲測定時の注意点として正しいのはどれか。",choices:["伸展位で行う","股関節を屈曲位で行う","股関節を伸展位で行う","膝関節を完全伸展位から測定する"],ans:1,exp:"膝関節屈曲は股関節を屈曲位で行う。基本軸は大腿骨、移動軸は腓骨（腓骨頭と外果を結ぶ線）。"},
