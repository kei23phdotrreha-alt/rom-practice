  {id:49,sec:"足関節・足部",q:"足関節内がえし・外がえしの基本軸として正しいのはどれか。",choices:["矢状面における腓骨長軸への垂直線","前額面における下腿軸への垂直線","第2中足骨長軸","足底面"],ans:1,exp:"内がえし・外がえしの基本軸は前額面における下腿軸への垂直線、移動軸は足底面。膝関節屈曲位・足関節0度で行う。"},
];

const LABELS = ['A','B','C','D'];
const SECTIONS = ["測定法・概念","肩甲帯","肩関節","肘関節・前腕","手関節","手指・母指","股関節","膝関節","足関節・足部"];
const STORAGE_KEY = 'rom_app_v1';

// ===== State =====
let state = { attempts:0, totalCorrect:0, totalAnswered:0, perQ:{} }; // perQ[id] = {correct, total}
let session = { mode:'all', queue:[], idx:0, results:[] };

function loadState() {
  try { const d = localStorage.getItem(STORAGE_KEY); if(d) state = JSON.parse(d); } catch(e){}
}
function saveState() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e){}
}

function shuffle(arr) {
  const a = [...arr];
  for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
  return a;
}

function getWeakQuestions() {
  return QUESTIONS.filter(q => {
    const p = state.perQ[q.id];
    if(!p || p.total===0) return false;
    return (p.correct/p.total) < 0.5;
  });
}

function getWeakSections() {
  const secData = {};
  SECTIONS.forEach(s => secData[s] = {correct:0,total:0});
  QUESTIONS.forEach(q => {
    const p = state.perQ[q.id];
    if(!p) return;
    secData[q.sec].correct += p.correct;
    secData[q.sec].total += p.total;
  });
  return SECTIONS.filter(s => secData[s].total > 0 && secData[s].correct/secData[s].total < 0.5);
}

function updateHomeStats() {
  const rate = state.totalAnswered > 0 ? Math.round(state.totalCorrect/state.totalAnswered*100) : null;
  document.getElementById('home-rate').innerHTML = rate !== null ? `${rate}<span class="stat-unit">%</span>` : `—<span class="stat-unit">%</span>`;
  document.getElementById('home-attempts').innerHTML = `${state.attempts}<span class="stat-unit">回</span>`;
  document.getElementById('home-correct').textContent = state.totalCorrect;
  const weakQ = getWeakQuestions();
  document.getElementById('home-weak').innerHTML = `${weakQ.length}<span class="stat-unit">問</span>`;

  const weakSecs = getWeakSections();
  const tagsEl = document.getElementById('weak-section-tags');
  if(weakSecs.length === 0) {
    tagsEl.innerHTML = '<span class="no-weak">' + (state.totalAnswered > 0 ? '苦手なセクションはありません 🎉' : 'まだデータがありません') + '</span>';
  } else {
    tagsEl.innerHTML = weakSecs.map(s => `<span class="weak-tag">${s}</span>`).join('');
  }
}

function startQuiz(mode) {
  session.mode = mode;
  let pool;
  if(mode === 'weak') {
    pool = getWeakQuestions();
    if(pool.length === 0) { showToast('苦手問題がまだありません。全問モードで練習しましょう！'); startQuiz('all'); return; }
  } else {
    pool = [...QUESTIONS];
  }
  session.queue = shuffle(pool);
  session.idx = 0;
  session.results = [];
  showScreen('quiz');
  document.getElementById('quiz-mode-label').textContent = mode === 'weak' ? '苦手集中' : 'ランダム';
  renderQuestion();
}

function renderQuestion() {
  const total = session.queue.length;
  const idx = session.idx;
  const q = session.queue[idx];
  const pct = Math.round((idx+1)/total*100);

  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('quiz-counter').textContent = `${idx+1} / ${total}`;
  document.getElementById('next-area').classList.remove('show');
  document.getElementById('next-btn').textContent = idx === total-1 ? '結果を見る →' : '次の問題 →';
  if(idx === total-1) document.getElementById('next-btn').classList.add('gold-btn');
  else document.getElementById('next-btn').classList.remove('gold-btn');

  const html = `
    <div class="section-chip">${q.sec}</div>
    <div class="question-card">
      <div class="question-num">Q${idx+1}</div>
      <div class="question-text">${q.q}</div>
    </div>
    <div class="choices" id="choices">
      ${q.choices.map((c,i) => `
        <button class="choice-btn" id="choice-${i}" onclick="answer(${i})">
          <span class="choice-label">${LABELS[i]}</span>
          <span>${c}</span>
        </button>
      `).join('')}
    </div>
    <div class="explanation" id="explanation">
      <div class="exp-header">
        <span class="exp-badge" id="exp-badge">解説</span>
      </div>
      <div class="exp-text">${q.exp}</div>
    </div>
  `;
  document.getElementById('quiz-body').innerHTML = html;
  document.getElementById('quiz-body').scrollTop = 0;
}

function answer(chosen) {
  const q = session.queue[session.idx];
  const isCorrect = chosen === q.ans;

  // Update state
  if(!state.perQ[q.id]) state.perQ[q.id] = {correct:0,total:0};
  state.perQ[q.id].total++;
  if(isCorrect) state.perQ[q.id].correct++;
  saveState();

  session.results.push({q, chosen, correct: isCorrect});

  // Visual feedback
  document.querySelectorAll('.choice-btn').forEach((btn,i) => {
    btn.classList.add('disabled');
    if(i === q.ans) btn.classList.add('correct');
    else if(i === chosen && !isCorrect) btn.classList.add('wrong');
  });

  const exp = document.getElementById('explanation');
  const badge = document.getElementById('exp-badge');
  exp.classList.add('show');
  badge.textContent = isCorrect ? '✓ 正解' : '✗ 不正解';
  badge.className = 'exp-badge ' + (isCorrect ? 'ok' : 'ng');

  document.getElementById('next-area').classList.add('show');
}

function nextQuestion() {
  session.idx++;
  if(session.idx >= session.queue.length) {
    showResult();
  } else {
    renderQuestion();
    document.getElementById('quiz-body').scrollTop = 0;
  }
}

function showResult() {
  // Update global stats
  const correct = session.results.filter(r=>r.correct).length;
  const total = session.results.length;
  state.attempts++;
  state.totalCorrect += correct;
  state.totalAnswered += total;
  saveState();

  showScreen('result');

  const pct = Math.round(correct/total*100);
  document.getElementById('result-pct').innerHTML = `${pct}<span class="score-pct-sym">%</span>`;

  let grade = pct >= 90 ? '優秀' : pct >= 80 ? 'よくできました' : pct >= 70 ? '合格レベル' : '要復習';
  document.getElementById('result-grade').textContent = grade;
  document.getElementById('r-correct').textContent = correct;
  document.getElementById('r-wrong').textContent = total - correct;
  document.getElementById('r-total').textContent = total;

  // Ring animation
  const circumference = 439.8;
  const fill = document.getElementById('ring-fill');
  const ringColor = pct >= 80 ? '#C9A84C' : pct >= 60 ? '#4ECDC4' : '#ff6b6b';
  fill.setAttribute('stroke', ringColor);
  setTimeout(() => {
    fill.style.strokeDashoffset = circumference * (1 - pct/100);
  }, 100);

  // Section chart
  const secData = {};
  SECTIONS.forEach(s => secData[s] = {correct:0,total:0});
  session.results.forEach(r => {
    secData[r.q.sec].total++;
    if(r.correct) secData[r.q.sec].correct++;
  });
  let chartHtml = '';
  SECTIONS.forEach(s => {
    const d = secData[s];
    if(d.total === 0) return;
    const p = Math.round(d.correct/d.total*100);
    const color = p >= 80 ? '#C9A84C' : p >= 60 ? '#4ECDC4' : '#ff6b6b';
    chartHtml += `
      <div class="sc-row">
        <div class="sc-label">${s}</div>
        <div class="sc-bar-wrap"><div class="sc-bar" style="width:0%;background:${color}" data-pct="${p}"></div></div>
        <div class="sc-pct">${p}%</div>
      </div>`;
  });
  document.getElementById('section-chart-body').innerHTML = chartHtml;
  setTimeout(() => {
    document.querySelectorAll('.sc-bar').forEach(b => b.style.width = b.dataset.pct + '%');
  }, 200);

  // Wrong list
  const wrongs = session.results.filter(r=>!r.correct);
  let wrongHtml = '';
  if(wrongs.length > 0) {
    wrongHtml = `<div class="wrong-title">❌ 間違えた問題（${wrongs.length}問）</div>`;
    wrongs.forEach(r => {
      wrongHtml += `
        <div class="wrong-item">
          <div class="wrong-q">${r.q.q}</div>
          <div class="wrong-ans">あなたの答え：${LABELS[r.chosen]}. ${r.q.choices[r.chosen]}</div>
          <div class="wrong-cor">正解：${LABELS[r.q.ans]}. ${r.q.choices[r.q.ans]}</div>
        </div>`;
    });
  } else {
    wrongHtml = `<div style="text-align:center;color:rgba(255,255,255,0.4);font-size:14px;padding:20px 0">全問正解です！🎉</div>`;
  }
  document.getElementById('wrong-section').innerHTML = wrongHtml;
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

function goHome() {
  updateHomeStats();
  showScreen('home');
}

function confirmReset() {
  if(confirm('学習履歴をすべてリセットしますか？')) {
    state = { attempts:0, totalCorrect:0, totalAnswered:0, perQ:{} };
    saveState();
    updateHomeStats();
    showToast('履歴をリセットしました');
  }
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// Init
loadState();
updateHomeStats();
</script>
</body>
</html>
